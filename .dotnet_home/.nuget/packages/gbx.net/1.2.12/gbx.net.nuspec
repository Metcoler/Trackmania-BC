<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>GBX.NET</id>
    <version>1.2.12</version>
    <authors>Petr Pivoňka (BigBang1112)</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <projectUrl>https://github.com/BigBang1112/gbx-net</projectUrl>
    <description>C#/.NET parser for Gbx files from Nadeo games. Supports deserialization of 150+ nodes, where 50 %+ can be serialized back to Gbx.</description>
    <copyright>Copyright © Petr 'BigBang1112' Pivoňka</copyright>
    <tags>gbx, trackmania, maniaplanet, gamebox, net, chunk</tags>
    <repository type="git" url="https://github.com/BigBang1112/gbx-net" commit="c7b51543c30f29fb21ac7aa961baabfac9cd7b50" />
